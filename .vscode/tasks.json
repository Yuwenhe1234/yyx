{
  "version": "5.2.6",
  "tasks": [
    {
      "label": "ESP-IDF Watch Build",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\watch-build.ps1"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
